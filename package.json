{
  "name": "obs-music-widget",
  "version": "1.0.0",
  "description": "GitHub Pages OBS Browser Source widget powered by Spotify currently playing data.",
  "main": "dist/server.js",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "ts-node src/server.ts",
    "build": "npm run clean && tsc",
    "start": "node dist/server.js",
    "site:check": "node --check docs/app.js",
    "test": "npm run site:check && node --test --require ts-node/register tests/**/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "obs",
    "spotify",
    "websocket",
    "widget"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/ws": "^8.5.13",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
